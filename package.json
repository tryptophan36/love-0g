{
  "name": "love-0g",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:orchestrator": "npm run dev --prefix src/app/orchestrator",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:orchestrator\"",
    "build": "next build",
    "start": "next start",
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network zgTestnet",
    "deploy:reputation": "hardhat run scripts/deploy-reputation.ts --network zgTestnet",
    "install:all": "npm install && npm install --prefix src/app/orchestrator"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.1.0",
    "@tanstack/react-query": "^5.50.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.14.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "hardhat": "^2.28.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "@types/react": "19.2.14"
  }
}

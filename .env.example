# ============================================================
# LOVE-0G Environment Configuration
# ============================================================

# ------------------------------------------------------------
# DEPLOYMENT (Hardhat)
# ------------------------------------------------------------
# Private key for deploying contracts (without 0x prefix works too)
PRIVATE_KEY=your_private_key_here

# ------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------
# WalletConnect Project ID - get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# 0G Network RPC
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Contract addresses (populated after deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_deployed_agentic_id_address
NEXT_PUBLIC_INFT_CONTRACT=0x_deployed_agentic_id_address
NEXT_PUBLIC_REPUTATION_CONTRACT=0x_deployed_reputation_address

# ------------------------------------------------------------
# ORCHESTRATOR (Backend)
# ------------------------------------------------------------
# 0G Network
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=0x...                  # orchestrator backend wallet (needs 0G tokens)

# 0G Compute - AI inference endpoint
# Get credentials: 0g-compute-cli inference get-secret
ZG_SERVICE_URL=https://inference-api.0g.ai
ZG_API_SECRET=app-sk-...
ZG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836

# Contract addresses (same as above, for orchestrator)
INFT_CONTRACT=0x_deployed_agentic_id_address
REPUTATION_CONTRACT=0x_deployed_reputation_address

# Server port
PORT=3001
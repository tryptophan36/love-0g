# WalletConnect Project ID - get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Contract address (deploy using `npm run compile && npx hardhat run scripts/deploy.ts` from project root)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_deployed_contract_address

# .env.example

# 0G Network
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=0x...                  # orchestrator backend wallet (funded)

# 0G Compute (get from CLI: 0g-compute-cli inference get-secret)
ZG_SERVICE_URL=https://...
ZG_API_SECRET=app-sk-...
ZG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836

# iNFT Contract (pre-deployed on Galileo testnet)
INFT_CONTRACT=0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F

# Reputation Contract (you deploy this)
REPUTATION_CONTRACT=0x...

# App
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_INFT_CONTRACT=0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F
NEXT_PUBLIC_REPUTATION_CONTRACT=0x...
PORT=3001